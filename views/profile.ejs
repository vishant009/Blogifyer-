<%- include('partials/head') %>
<%- include('partials/nav') %>

<div style="background:url('<%= profileUser.profileImageURL %>') center/cover;height:200px"></div>
<div class="container" style="max-width:800px;margin:auto;padding:2rem 1rem">
  <div class="card" style="margin-top:-4rem;position:relative">
    <img src="<%= profileUser.profileImageURL %>" class="avatar" style="width:6rem;height:6rem;border:4px solid var(--bg)">
    <h1 style="margin:.5rem 0"><%= profileUser.fullname %></h1>
    <p style="color:var(--text-soft)"><%= profileUser.bio %></p>
    <div class="flex" style="margin-top:1rem">
      <span><%= profileUser.followers.length %> Followers</span>
      <span><%= profileUser.following.length %> Following</span>
    </div>
    <% if(user && user._id.toString() !== profileUser._id.toString()){ %>
      <form action="/user/<%= isFollowing ? 'unfollow' : 'follow' %>/<%= profileUser._id %>" method="post" style="margin-top:1rem">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn <%= isFollowing ? 'btn-ghost' : 'btn-primary' %>">
          <%= isFollowing ? 'Unfollow' : 'Follow' %>
        </button>
      </form>
    <% } %>
  </div>

  <h2 style="margin:2rem 0 1rem">Blogs</h2>
  <div class="grid grid-3">
    <% blogs.forEach(b=>{ %>
      <article class="card">
        <a href="/blog/<%= b._id %>">
          <img src="<%= b.coverImage || '/images/default-cover.jpg' %>" style="border-radius:var(--radius);margin-bottom:.5rem">
        </a>
        <h3 style="font-size:1.125rem"><a href="/blog/<%= b._id %>"><%= b.title %></a></h3>
      </article>
    <% }) %>
    <% if(blogs.length===0){ %><p style="color:var(--text-soft)">No blogs yet.</p><% } %>
  </div>
</div>
