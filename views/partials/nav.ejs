<header class="sticky">
  <div class="container flex-between" style="padding:.75rem 1rem">
    <a href="/" class="flex" style="font-weight:700;font-size:1.25rem">Blogify</a>

  <!-- Search -->
  <form action="/search" method="GET" class="flex" style="flex:1;max-width:400px;margin:0 1rem">
    <input name="q" placeholder="Search blogs or users…" autocomplete="off"
           style="width:100%;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg-soft);color:var(--text)">
  </form>

  <!-- Desktop nav -->
  <nav class="flex" style="gap:1rem">
    <% if(user){ %>
      <a href="/blog/addBlog" class="btn btn-primary">Write</a>
      <a href="/notification" title="Notifications"><span>🔔</span></a>
      <div class="dropdown" style="position:relative">
        <img src="<%= user.profileImageURL %>" alt="avatar" class="avatar">
        <div class="dropdown-menu" style="position:absolute;right:0;top:3rem;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:.5rem 0;display:none">
          <a href="/profile" style="display:block;padding:.5rem 1rem">Profile</a>
          <a href="/settings" style="display:block;padding:.5rem 1rem">Settings</a>
          <form action="/user/logout" method="GET"><button class="btn-ghost" style="width:100%;text-align:left;padding:.5rem 1rem">Logout</button></form>
        </div>
      </div>
    <% }else{ %>
      <a href="/user/signin" class="btn btn-ghost">Sign In</a>
      <a href="/user/signup" class="btn btn-primary">Sign Up</a>
    <% } %>
  </nav>

  <!-- Hamburger -->
  <button id="hamburger" class="btn-icon" style="display:none">☰</button>
  </div>
</header>

<!-- Drawer (mobile) -->
<div class="drawer" id="drawer">
  <div class="drawer-content">
    <button id="closeDrawer" style="margin-bottom:1rem">✕</button>
    <% if(user){ %>
      <a href="/profile" class="flex" style="margin-bottom:1rem"><img src="<%= user.profileImageURL %>" class="avatar"><%= user.fullname %></a>
      <a href="/blog/addBlog" class="btn btn-primary" style="width:100%;margin-bottom:.5rem">Write</a>
      <a href="/notification" class="btn-ghost" style="width:100%;margin-bottom:.5rem">Notifications</a>
      <a href="/settings" class="btn-ghost" style="width:100%;margin-bottom:.5rem">Settings</a>
      <form action="/user/logout" method="GET"><button class="btn-ghost" style="width:100%">Logout</button></form>
    <% }else{ %>
      <a href="/user/signin" class="btn btn-ghost" style="width:100%;margin-bottom:.5rem">Sign In</a>
      <a href="/user/signup" class="btn btn-primary" style="width:100%">Sign Up</a>
    <% } %>
  </div>
</div>

<script>
/* nav.js */
const hamburger=document.getElementById('hamburger'),drawer=document.getElementById('drawer');
const toggle=()=>drawer.classList.toggle('open');
hamburger.onclick=toggle;
document.getElementById('closeDrawer').onclick=toggle;
window.addEventListener('resize',()=>window.innerWidth>768?drawer.classList.remove('open'):null);

/* dropdown */
document.querySelector('.dropdown img').addEventListener('click',()=>{
  document.querySelector('.dropdown-menu').classList.toggle('hidden');
});
</script>
<style>
@media(max-width:768px){nav{display:none}#hamburger{display:block}}
</style>
