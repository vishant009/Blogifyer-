<header style="position:sticky;top:0;background:#2c3e50;padding:.6rem 1rem;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #34495e;z-index:1000">
  <a href="/" class="logo" style="color:#3498db;font-size:1.4rem;font-weight:bold;text-decoration:none"><i class="fas fa-blog"></i> Blogify</a>
  <form action="/search" method="GET" style="display:flex;gap:.4rem">
    <input type="text" name="q" placeholder="Search…" required style="padding:.35rem;border-radius:4px;border:1px solid #34495e;background:#34495e;color:#ecf0f1">
    <button style="background:#3498db;border:none;padding:.35rem .6rem;border-radius:4px;color:#fff"><i class="fas fa-search"></i></button>
  </form>
  <% if(user){ %>
    <img src="<%= user.profileImageURL||'/default.png' %>" style="width:32px;height:32px;border-radius:50%;cursor:pointer" onclick="toggleMenu()">
    <div id="menu" style="display:none;position:absolute;right:1rem;top:50px;background:#2c3e50;border:1px solid #34495e;border-radius:4px">
      <a href="/profile" style="display:block;padding:.5rem;color:#fff;text-decoration:none">Profile</a>
      <a href="/notification" style="display:block;padding:.5rem;color:#fff;text-decoration:none">Notifications</a>
      <a href="/settings" style="display:block;padding:.5rem;color:#fff;text-decoration:none">Settings</a>
      <a href="/user/logout" style="display:block;padding:.5rem;color:#fff;text-decoration:none">Logout</a>
    </div>
  <% }else{ %>
    <div><a href="/user/signin" style="color:#fff;margin-right:1rem">Sign In</a><a href="/user/signup" style="color:#fff">Sign Up</a></div>
  <% } %>
</header>
<script>function toggleMenu(){const m=document.getElementById('menu');m.style.display=m.style.display==='block'?'none':'block'}</script>
