<header style="position:sticky;top:0;background:#2c3e50;padding:.6rem 1rem;display:flex;align-items:center;justify-content:space-between;z-index:1000;border-bottom:1px solid #34495e">
  <a href="/" style="color:#3498db;font-size:1.4rem;font-weight:bold;text-decoration:none"><i class="fas fa-blog"></i> Blogify</a>
  <form action="/search" method="GET" style="display:flex;gap:.4rem">
    <input type="text" name="q" placeholder="Search…" required style="padding:.3rem;border-radius:4px;border:1px solid #34495e;background:#34495e;color:#ecf0f1">
    <button style="background:#3498db;border:none;padding:.3rem .6rem;border-radius:4px;color:#fff"><i class="fas fa-search"></i></button>
  </form>
  <% if(user){ %>
    <div style="position:relative">
      <img src="<%= user.profileImageURL %>" style="width:32px;height:32px;border-radius:50%;cursor:pointer" onclick="toggleMenu()">
      <div id="menu" style="display:none;position:absolute;right:0;top:35px;background:#2c3e50;border:1px solid #34495e;border-radius:4px">
        <a href="/profile" style="display:block;padding:.5rem;color:#ecf0f1;text-decoration:none">Profile</a>
        <a href="/notification" style="display:block;padding:.5rem;color:#ecf0f1;text-decoration:none">Notifications</a>
        <a href="/settings" style="display:block;padding:.5rem;color:#ecf0f1;text-decoration:none">Settings</a>
        <a href="/user/logout" style="display:block;padding:.5rem;color:#ecf0f1;text-decoration:none">Logout</a>
      </div>
    </div>
  <% }else{ %>
    <div>
      <a href="/user/signin" style="color:#ecf0f1;margin-right:1rem">Sign In</a>
      <a href="/user/signup" style="color:#ecf0f1">Sign Up</a>
    </div>
  <% } %>
</header>
<script>
  function toggleMenu(){const m=document.getElementById('menu');m.style.display=m.style.display==='none'||!m.style.display?'block':'none'}
</script>
