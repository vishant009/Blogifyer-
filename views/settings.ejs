<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container" style="max-width:800px;margin:auto;padding:2rem 1rem;display:flex;gap:2rem">
  <aside style="min-width:180px">
    <h3>Settings</h3>
    <nav style="display:flex;flex-direction:column;gap:.5rem;margin-top:1rem">
      <a href="#profile" onclick="showTab('profile')">Profile</a>
      <a href="#password" onclick="showTab('password')">Password</a>
      <a href="#danger" onclick="showTab('danger')">Delete Account</a>
    </nav>
  </aside>

  <main style="flex:1">
    <form id="profile" class="tab card" action="/settings/update-profile" method="post" enctype="multipart/form-data">
      <h2>Profile</h2>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Full Name<input type="text" name="fullname" value="<%= user.fullname %>" style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"></label>
      <label>Bio<textarea name="bio" rows="3" style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"><%= user.bio %></textarea></label>
      <label>Visibility
        <select name="visibility" style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)">
          <option value="public" <%= visibility==='public' ? 'selected' : '' %>>Public</option>
          <option value="followers" <%= visibility==='followers' ? 'selected' : '' %>>Followers only</option>
          <option value="private" <%= visibility==='private' ? 'selected' : '' %>>Private</option>
        </select>
      </label>
      <label>Profile Image<input type="file" name="profileImage" accept="image/*" style="margin:.5rem 0 1rem"></label>
      <button class="btn btn-primary">Save</button>
    </form>

    <form id="password" class="tab card hidden" action="/settings/reset-password" method="post">
      <h2>Change Password</h2>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="userId" value="<%= user._id %>">
      <input type="hidden" name="token" value="">
      <label>New Password<input type="password" name="password" minlength="8" required style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"></label>
      <label>Confirm<input type="password" name="confirmPassword" required style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"></label>
      <button class="btn btn-primary">Update</button>
    </form>

    <form id="danger" class="tab card hidden" onsubmit="return confirmDelete()">
      <h2 style="color:#ef4444">Delete Account</h2>
      <p>This action cannot be undone.</p>
      <input type="password" id="deletePw" placeholder="Enter password to confirm" required style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)">
      <button class="btn" style="background:#ef4444;color:#fff">Delete Forever</button>
    </form>
  </main>
</div>

<script>
function showTab(id){
  document.querySelectorAll('.tab').forEach(t=>t.classList.add('hidden'));
  document.getElementById(id).classList.remove('hidden');
}
function confirmDelete(){
  if(document.getElementById('deletePw').value){
    fetch('/settings/delete-account',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:document.getElementById('deletePw').value})})
    .then(r=>r.json()).then(d=>{
      if(d.success){location.href='/';}
      else toast(d.error,'error');
    });
  }
  return false;
}
</script>
