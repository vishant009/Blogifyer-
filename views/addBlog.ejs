<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container" style="max-width:800px;margin:auto;padding:2rem 1rem">
  <h1 style="margin-bottom:1rem"><%= typeof blog !== 'undefined' ? 'Edit Blog' : 'Add New Blog' %></h1>

  <form action="<%= blog ? '/blog/'+blog._id+'?_method=PUT' : '/blog' %>"
        method="post" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Title<input type="text" name="title" value="<%= blog?.title || '' %>" required style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"></label>
    <label>Body<textarea name="body" rows="10" required style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"><%= blog?.body || '' %></textarea></label>
    <label>Category
      <select name="category" style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)">
        <% categories.forEach(c=>{ %>
          <option value="<%= c %>" <%= blog?.category===c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
    </label>
    <label>Tags<input type="text" name="tags" value="<%= blog?.tags.join(', ') || '' %>" placeholder="tech, life, etc" style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"></label>
    <label>Cover Image<input type="file" name="coverImage" accept="image/*" style="margin:.5rem 0 1rem"></label>
    <div>
      <button class="btn btn-primary" type="submit" name="status" value="published">Publish</button>
      <button class="btn btn-ghost" type="submit" name="status" value="draft">Save as Draft</button>
    </div>
  </form>
</div>
