<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Search | Blogify</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <style>
    body{margin:0;background:#1a2634;color:#ecf0f1;font-family:Arial}
    .container{max-width:800px;margin:2rem auto;padding:1rem}
    .result{background:#2c3e50;margin-bottom:.8rem;padding:1rem;border-radius:8px;display:flex;align-items:center;gap:1rem}
    .result img{width:40px;height:40px;border-radius:50%;object-fit:cover}
    .result a{color:#3498db;text-decoration:none}
  </style>
</head>
<body>
<%- include('partials/header', { user }) %>
<div class="container">
  <h1>Search Results for "<%= query %>"</h1>
  <% if(success_msg){ %><p style="color:#27ae60"><%= success_msg %></p><% } %>
  <% if(error_msg){ %><p style="color:#e74c3c"><%= error_msg %></p><% } %>

  <h2>Users</h2>
  <% if(users.length){ %><% users.forEach(u=>{ %><div class="result"><img src="<%= u.profileImageURL||'/default.png' %>"><a href="/profile/<%= u._id %>"><%= u.fullname %></a></div><% }) %><% }else{ %><p>No users.</p><% } %>

  <h2>Blogs</h2>
  <% if(blogs.length){ %><% blogs.forEach(b=>{ %><div class="result"><a href="/blog/<%= b._id %>"><%= b.title %></a> – <small><%= moment(b.createdAt).fromNow() %></small></div><% }) %><% }else{ %><p>No blogs.</p><% } %>
</div>
</body>
</html>
