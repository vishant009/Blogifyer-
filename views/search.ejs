<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container" style="max-width:800px;margin:auto;padding:2rem 1rem">
  <form action="/search" method="get">
    <input type="text" name="q" value="<%= query %>" placeholder="Search…" autofocus
           style="width:100%;padding:.75rem;border-radius:var(--radius);border:1px solid var(--border);margin-bottom:1rem">
  </form>

  <h2>Users</h2>
  <div class="grid grid-3">
    <% users.forEach(u=>{ %>
      <div class="card flex">
        <img src="<%= u.profileImageURL %>" class="avatar">
        <div>
          <a href="/profile/<%= u._id %>"><%= u.fullname %></a><br>
          <small><%= u.followers.length %> followers</small>
        </div>
      </div>
    <% }) %>
  </div>

  <h2 style="margin-top:2rem">Blogs</h2>
  <div class="grid grid-3">
    <% blogs.forEach(b=>{ %>
      <article class="card">
        <a href="/blog/<%= b._id %>">
          <img src="<%= b.coverImage || '/images/default-cover.jpg' %>" style="border-radius:var(--radius);margin-bottom:.5rem">
        </a>
        <h3><a href="/blog/<%= b._id %>"><%= b.title %></a></h3>
        <small style="color:var(--text-soft)"><%= b.createdBy.fullname %></small>
      </article>
    <% }) %>
  </div>

  <% if(!users.length && !blogs.length && query){ %>
    <p style="text-align:center;color:var(--text-soft)">No results for “<%= query %>”.</p>
  <% } %>
</div>
