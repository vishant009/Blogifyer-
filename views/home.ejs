<%- include('partials/head') %>
<%- include('partials/nav') %>

<section style="padding:3rem 0;text-align:center;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff">
  <div class="container">
    <h1 style="font-size:2.5rem;margin-bottom:.5rem">Welcome to Blogify</h1>
    <p style="font-size:1.125rem;margin-bottom:1.5rem">Read, write and share ideas with the world.</p>
    <% if(!user){ %><a href="/user/signup" class="btn" style="background:#fff;color:var(--primary)">Start Writing</a><% } %>
  </div>
</section>

<main class="container" style="padding:2rem 0">
  <div class="grid grid-3" id="blogGrid">
    <% blogs.forEach(b=>{ %>
    <article class="card">
      <a href="/blog/<%= b._id %>">
        <img src="<%= b.coverImage || '/images/default-cover.jpg' %>" alt="" style="border-radius:var(--radius);margin-bottom:.75rem">
      </a>
      <h2 style="font-size:1.25rem;margin-bottom:.5rem"><a href="/blog/<%= b._id %>"><%= b.title %></a></h2>
      <div class="flex" style="font-size:.875rem;color:var(--text-soft)">
        <img src="<%= b.createdBy.profileImageURL %>" class="avatar">
        <span><%= b.createdBy.fullname %></span>
      </div>
      <div class="flex" style="margin-top:.75rem;font-size:.875rem">
        <span>❤️ <%= b.likes.length %></span>
        <span>💬 <%= b.comments.length %></span>
      </div>
    </article>
    <% }) %>
  </div>
  <% if(blogs.length===0){ %>
    <div style="text-align:center;color:var(--text-soft)">No blogs yet.</div>
  <% } %>
</main>

<%- include('partials/toast') %>
<script>
/* lazy toast */
const url=new URLSearchParams(location.search);
if(url.get('success_msg')) toast(url.get('success_msg'),'success');
if(url.get('error_msg')) toast(url.get('error_msg'),'error');

/* infinite scroll placeholder (optional) */
</script>
