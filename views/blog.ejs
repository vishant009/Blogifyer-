<%- include('partials/head') %>
<%- include('partials/nav') %>

<article>
  <img src="<%= blog.coverImage || '/images/default-cover.jpg' %>" alt="" style="width:100%;max-height:400px;object-fit:cover">
  <div class="container" style="max-width:800px;margin:auto;padding:2rem 1rem">
    <h1 style="font-size:2rem;margin-bottom:.5rem"><%= blog.title %></h1>
    <div class="flex" style="margin-bottom:1.5rem">
      <img src="<%= blog.createdBy.profileImageURL %>" class="avatar">
      <div>
        <b><%= blog.createdBy.fullname %></b><br>
        <small style="color:var(--text-soft)"><%= moment(blog.createdAt).format('MMM Do, YYYY') %></small>
      </div>
      <% if(user && user._id.toString() !== blog.createdBy._id.toString()){ %>
        <form action="/blog/<%= blog._id %>/like" method="post" style="margin-left:auto">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-icon" title="Like">❤️ <%= blog.likes.length %></button>
        </form>
      <% } %>
    </div>

    <div class="prose" style="word-break:break-word"><%- blog.body %></div>

    <!-- Comments -->
    <h3 style="margin:2rem 0 1rem">Comments</h3>
    <% if(user){ %>
      <form action="/comment/<%= blog._id %>" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <textarea name="content" rows="3" placeholder="Write a comment…" required style="width:100%;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"></textarea>
        <button class="btn btn-primary" style="margin-top:.5rem">Post</button>
      </form>
    <% } %>
    <div style="margin-top:1rem">
      <% comments.forEach(c=>{ %>
        <div class="card" style="margin-bottom:1rem">
          <div class="flex">
            <img src="<%= c.createdBy.profileImageURL %>" class="avatar">
            <div>
              <b><%= c.createdBy.fullname %></b>
              <small style="color:var(--text-soft)"><%= moment(c.createdAt).fromNow() %></small>
            </div>
          </div>
          <p style="margin:.5rem 0"><%= c.content %></p>
          <small>❤️ <%= c.likes.length %></small>
        </div>
      <% }) %>
    </div>
  </div>
</article>

<%- include('partials/toast') %>
<script>
const url=new URLSearchParams(location.search);
if(url.get('success_msg')) toast(url.get('success_msg'),'success');
if(url.get('error_msg')) toast(url.get('error_msg'),'error');
</script>
