<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Edit Blog | Blogify</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <style>
    body{margin:0;background:#1a2634;color:#ecf0f1;font-family:Arial}
    .container{max-width:600px;margin:2rem auto;padding:1rem}
    input,textarea,select{width:100%;padding:.7rem;margin:.5rem 0;border:1px solid #34495e;border-radius:4px;background:#34495e;color:#ecf0f1}
    button{padding:.7rem;background:#3498db;border:none;border-radius:4px;color:#fff;cursor:pointer}
  </style>
</head>
<body>
<%- include('partials/header', { user }) %>
<div class="container">
  <h1><i class="fas fa-edit"></i> Edit Blog</h1>
  <% if(error_msg){ %><p style="color:#e74c3c"><%= error_msg %></p><% } %>
  <form action="/blog/<%= blog._id %>?_method=PUT" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="text" name="title" value="<%= blog.title %>" placeholder="Title" required>
    <textarea name="body" rows="6" placeholder="Content" required><%= blog.body %></textarea>
    <select name="category">
      <% categories.forEach(c=>{ %><option value="<%= c %>" <%= blog.category===c?'selected':'' %>><%= c %></option><% }) %>
    </select>
    <input type="text" name="tags" value="<%= blog.tags.join(',') %>" placeholder="Tags (comma separated)">
    <select name="status">
      <option value="published" <%= blog.status==='published'?'selected':'' %>>Publish</option>
      <option value="draft" <%= blog.status==='draft'?'selected':'' %>>Save as Draft</option>
    </select>
    <input type="file" name="coverImage" accept="image/*">
    <button type="submit">Update Blog</button>
  </form>
</div>
</body>
</html>
