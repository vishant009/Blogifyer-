<%- include('partials/head') %>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:linear-gradient(135deg,var(--primary),var(--accent))">
  <div class="card" style="width:100%;max-width:380px;padding:2rem">
    <h1 style="text-align:center;margin-bottom:1.5rem">Sign In</h1>
    <form action="/user/signin" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Email<input type="email" name="email" value="<%= email %>" required style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"></label>
      <label>Password<input type="password" name="password" required style="display:block;width:100%;margin:.5rem 0 1rem;padding:.5rem;border-radius:var(--radius);border:1px solid var(--border)"></label>
      <button class="btn btn-primary" style="width:100%">Sign In</button>
    </form>
    <p style="text-align:center;margin-top:1rem;font-size:.875rem">
      <a href="/user/forgot-password">Forgot password?</a> · <a href="/user/signup">Create account</a>
    </p>
  </div>
</body>
