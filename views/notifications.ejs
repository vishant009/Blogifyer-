<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Notifications | Blogify</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <style>
    body{margin:0;background:#1a2634;color:#ecf0f1;font-family:Arial}
    .container{max-width:600px;margin:2rem auto;padding:1rem}
    .note{background:#2c3e50;margin-bottom:.8rem;padding:1rem;border-radius:6px}
    .note img{width:40px;height:40px;border-radius:50%;vertical-align:middle;margin-right:.8rem}
    .note small{color:#7f8c8d}
  </style>
</head>
<body>
<%- include('partials/header', { user }) %>
<div class="container">
  <h1><i class="fas fa-bell"></i> Notifications</h1>
  <% if(success_msg){ %><p style="color:#27ae60"><%= success_msg %></p><% } %>
  <% if(error_msg){ %><p style="color:#e74c3c"><%= error_msg %></p><% } %>

  <% if(!notifications.length){ %><p>No notifications.</p><% } %>
  <% notifications.forEach(n=>{ %>
    <div class="note">
      <img src="<%= n.sender.profileImageURL||'/default.png' %>">
      <div>
        <strong><a href="/profile/<%= n.sender._id %>" style="color:#3498db"><%= n.sender.fullname %></a></strong> <%= n.message %> <br>
        <small><%= moment(n.createdAt).fromNow() %></small>
        <% if(n.type==='FOLLOW_REQUEST'&&n.status==='PENDING'){ %>
          <form action="/notification/accept/<%= n._id %>" method="POST" style="display:inline"><button>Accept</button></form>
          <form action="/notification/reject/<%= n._id %>" method="POST" style="display:inline"><button>Reject</button></form>
        <% }else if(n.status!=='READ'){ %>
          <form action="/notification/read/<%= n._id %>" method="POST" style="display:inline"><button>Mark read</button></form>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>
</body>
</html>
