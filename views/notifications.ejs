<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container" style="max-width:600px;margin:auto;padding:2rem 1rem">
  <h1>Notifications</h1>
  <% if(notifications.length===0){ %>
    <p style="color:var(--text-soft);margin-top:1rem">Nothing new 🎉</p>
  <% } %>
  <% notifications.forEach(n=>{ %>
    <div class="card" style="margin-bottom:1rem">
      <div class="flex">
        <img src="<%= n.sender.profileImageURL %>" class="avatar">
        <div>
          <p><%= n.message %></p>
          <small style="color:var(--text-soft)"><%= moment(n.createdAt).fromNow() %></small>
        </div>
      </div>
      <% if(n.type==='FOLLOW_REQUEST' && n.status==='PENDING'){ %>
        <div class="flex" style="margin-top:.5rem">
          <form action="/notification/accept/<%= n._id %>" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-primary">Accept</button>
          </form>
          <form action="/notification/reject/<%= n._id %>" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-ghost">Reject</button>
          </form>
        </div>
      <% } %>
    </div>
  <% }) %>
</div>
