<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Verify Email | Blogify</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <style>
    body{margin:0;background:#1a2634;color:#ecf0f1;font-family:Arial;display:flex;align-items:center;justify-content:center;height:100vh}
    .card{background:#2c3e50;padding:2rem;border-radius:8px;width:100%;max-width:400px;box-shadow:0 4px 12px rgba(0,0,0,.3)}
    h1{text-align:center;margin-bottom:1.2rem}
    .alert{padding:.8rem;border-radius:4px;margin-bottom:1rem}
    .success{background:#27ae6020;color:#27ae60}
    .error{background:#e74c3c20;color:#e74c3c}
    input{width:100%;padding:.75rem;margin:.5rem 0;border:1px solid #34495e;border-radius:4px;background:#34495e;color:#ecf0f1}
    button{width:100%;padding:.75rem;background:#3498db;border:none;border-radius:4px;color:#fff;font-size:1rem;cursor:pointer}
  </style>
</head>
<body>
<div class="card">
  <h1><i class="fas fa-key"></i> Verify Email</h1>
  <% if(error_msg){ %><div class="alert error"><%= error_msg %></div><% } %>
  <% if(success_msg){ %><div class="alert success"><%= success_msg %></div><% } %>
  <form method="POST" action="/user/verify-email">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="email" value="<%= email %>">
    <input type="text" name="code" placeholder="Verification code" required>
    <button type="submit">Verify</button>
  </form>
</div>
</body>
</html>
